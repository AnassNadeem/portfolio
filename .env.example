# ─────────────────────────────────────────────────────────────────
#  APEX PORTFOLIO — Environment Variables
#  Copy this file to .env.local for local dev.
#  Set all variables in Cloudflare Pages dashboard for production.
#  NEVER commit .env or .env.local — only this .env.example file.
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE (client-safe — anon key only) ───────────────────────
# Get these from: Supabase dashboard → Project Settings → API
# VITE_ prefix means these are embedded in the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CLOUDFLARE TURNSTILE (client-safe — site key only) ───────────
# Get from: Cloudflare dashboard → Turnstile → Add site
# Choose "Managed" widget type. Copy the Site Key (not the Secret Key).
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAA...

# ── LEGACY FORM / LEADERBOARD ENDPOINTS (optional, blank = disabled) ─
# These are only needed if NOT using Supabase.
# Leave blank once Supabase integration is live (Phases 3 & 4).
VITE_FORM_ENDPOINT=
VITE_LEADERBOARD_ENDPOINT=

# ─────────────────────────────────────────────────────────────────
#  SERVER-SIDE ONLY — Supabase Edge Function secrets
#  Set these in: Supabase dashboard → Edge Functions → Secrets
#  (or via `supabase secrets set KEY=value`)
#  These NEVER go in .env.local or Cloudflare Pages env vars.
# ─────────────────────────────────────────────────────────────────

# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← only used inside Edge Functions
# RESEND_API_KEY=re_...              ← get from resend.com → API Keys
# TURNSTILE_SECRET_KEY=0x4AAAAA...   ← Cloudflare Turnstile → Secret Key
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
#   ← Discord server → channel settings → Integrations → Webhooks → New Webhook → Copy URL
