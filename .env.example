# ─────────────────────────────────────────────────────────────────
#  APEX PORTFOLIO — Environment Variables
#  Copy this file to .env for local dev.
#  Set all variables in Cloudflare Pages dashboard for production.
#  NEVER commit .env — only this .env.example file.
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE (client-safe — anon key only) ───────────────────────
# Get these from: Supabase dashboard → Project Settings → API
# VITE_ prefix means these are embedded in the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SITE URL (used in og:url, canonical, sitemap) ────────────────
# Set to your production domain once you have one, e.g. https://anasnadeemdev.com
VITE_SITE_URL=https://yourdomain.com

# ── CLOUDFLARE TURNSTILE (client-safe — site key only) ───────────
# Get from: Cloudflare dashboard → Turnstile → Add site
# Choose "Managed" widget type. Copy the Site Key (not the Secret Key).
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAA...

# ── LEGACY FORM / LEADERBOARD ENDPOINTS (optional, blank = disabled) ─
# These are only needed if NOT using Supabase.
# Leave blank once Supabase integration is live (Phases 3 & 4).
VITE_FORM_ENDPOINT=
VITE_LEADERBOARD_ENDPOINT=

# ─────────────────────────────────────────────────────────────────
#  SERVER-SIDE ONLY — Supabase Edge Function secrets
#  Set these in: Supabase dashboard → Edge Functions → Secrets
#  (or via `supabase secrets set KEY=value`)
#  These NEVER go in .env or Cloudflare Pages env vars.
# ─────────────────────────────────────────────────────────────────

# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← only used inside Edge Functions
# RESEND_API_KEY=re_...              ← get from resend.com → API Keys
# NOTIFICATION_EMAIL=anass.nadeem42@gmail.com  ← contact form recipient (defaults to this if unset)
# TURNSTILE_SECRET_KEY=0x4AAAAA...   ← Cloudflare Turnstile → Secret Key
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
#   ← Discord server → channel settings → Integrations → Webhooks → New Webhook → Copy URL
#
# ── DEPLOYMENT CHECKLIST ───────────────────────────────────────────
# Contact form:
# 1. supabase db push  (migrations 001–004)
# 2. supabase functions deploy contact-submit
# 3. supabase functions deploy arcade-submit
# 3. supabase secrets set TURNSTILE_SECRET_KEY=... RESEND_API_KEY=... NOTIFICATION_EMAIL=anass.nadeem42@gmail.com
# 4. Copy this file to .env and fill in VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_TURNSTILE_SITE_KEY
# 5. Cloudflare Pages: same VITE_* vars for production
#
# Reset arcade DB (bots are in code, not DB):
#   Supabase → SQL Editor → run:
#   delete from public.arcade_scores;
#   delete from public.drivers;
#   delete from public.leaderboard;
#   delete from public.signups;
